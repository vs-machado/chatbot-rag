# Configuração do banco de dados PostgreSQL com pgvector
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/chatbot_rag

# Modelo de embeddings (Sentence Transformers)
# Opções: all-MiniLM-L6-v2 (384 dim), all-mpnet-base-v2 (768 dim), paraphrase-multilingual-MiniLM-L12-v2 (384 dim, multilingual)
EMBEDDING_MODEL=all-MiniLM-L6-v2
