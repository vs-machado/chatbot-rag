# Configuração do banco de dados PostgreSQL com pgvector
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/chatbot_rag

# Configuração de Embeddings
# Provedor: sentence_transformers, google, openai
EMBEDDING_PROVIDER=sentence_transformers

# Modelo (deve corresponder ao provedor):
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSION=1024

# Configuração de LLM
# Provedor: google, openai, openrouter
LLM_PROVIDER=google
# Modelo:
# - google: gemini-2.5-flash, gemini-2.5-pro
# - openai: gpt-4o, gpt-4o-mini
# - openrouter (grátis): arcee-ai/trinity-large-preview:free, openai/gpt-oss-120b:free
LLM_MODEL=gemini-2.5-flash

# API Keys (necessárias se usar provedores cloud)
GOOGLE_API_KEY=sua_chave_aqui
OPENAI_API_KEY=sua_chave_aqui
OPENROUTER_API_KEY=sua_chave_aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=chatbot-rag

# Configuração de Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
