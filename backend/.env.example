# Configuração do banco de dados PostgreSQL com pgvector
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/chatbot_rag

# Configuração de Embeddings
# Provedor: sentence_transformers, google, openai
EMBEDDING_PROVIDER=sentence_transformers
# Modelo (deve corresponder ao provedor):
# - sentence_transformers: all-MiniLM-L6-v2 (384 dim), all-mpnet-base-v2 (768 dim)
# - google: models/text-embedding-004 (768 dim)
# - openai: text-embedding-3-small (1536 dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Configuração de LLM
# Provedor: google, openai
LLM_PROVIDER=google
# Modelo:
# - google: gemini-1.5-flash, gemini-1.5-pro
# - openai: gpt-4o, gpt-4o-mini
LLM_MODEL=gemini-1.5-flash

# API Keys (necessárias se usar provedores cloud)
GOOGLE_API_KEY=sua_chave_aqui
OPENAI_API_KEY=sua_chave_aqui

# Configuração de Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
